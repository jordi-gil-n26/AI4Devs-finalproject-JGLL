# Frontend environment variables (Next.js)
#
# Copy this file to `.env.local` and fill in real values for local development.
# `.env.local` is gitignored by default in Next.js (created by T002 scaffold)
# and MUST NOT be committed. Only NEXT_PUBLIC_* variables are exposed to the
# browser bundle.

# Base URL of the backend API (Spring Boot, see plan.md).
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1

# Mapbox public access token used by react-map-gl on the search page.
# Create one at https://account.mapbox.com/access-tokens/ — public tokens
# start with "pk.". Never use a server-side token in this file.
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_token_here

# Stripe publishable key used by Stripe Elements during checkout.
# Use the test key (pk_test_...) for local development. The server-side key
# lives only on the backend and never appears here.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
